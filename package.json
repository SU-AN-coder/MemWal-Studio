{
  "name": "memwal-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "lint": "tsc -b --pretty false",
    "test": "vitest run",
    "verify:demo": "npm run build && npm test",
    "verify:config": "node scripts/verify-config.mjs",
    "memwal:configure": "node scripts/configure-memwal.mjs",
    "memwal:provision": "node scripts/provision-memwal-account.mjs",
    "verify:memwal": "node scripts/verify-memwal.mjs",
    "verify:storage": "node scripts/verify-walrus.mjs",
    "verify:aggregator": "node scripts/verify-walrus.mjs",
    "move:test": "cd move/memwal_studio && sui move test",
    "move:publish": "node scripts/publish-sui.mjs",
    "verify:seal": "node scripts/verify-seal.mjs",
    "verify:live": "npm run verify:config && npm run verify:storage && npm run verify:memwal && npm run verify:seal"
  },
  "dependencies": {
    "@mysten-incubation/memwal": "^0.0.7",
    "@mysten/dapp-kit": "^1.0.6",
    "@mysten/seal": "^1.1.3",
    "@mysten/sui": "^2.17.0",
    "@mysten/walrus": "^1.1.7",
    "@tanstack/react-query": "^5.101.0",
    "@types/dagre": "^0.7.54",
    "@vitejs/plugin-react": "^5.0.0",
    "@xyflow/react": "^12.11.0",
    "dagre": "^0.8.5",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "vite": "^8.0.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.8.0",
    "vitest": "^4.0.0"
  }
}
